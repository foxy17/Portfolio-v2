# Keystatic GitHub mode (production /keystatic dashboard).
# In dev the dashboard uses local filesystem storage, so these are only needed
# for the deployed site. Generate them by deploying, opening
# https://blog.carnav.in/keystatic, and clicking "Connect to GitHub" — Keystatic
# walks you through creating the GitHub App and prints these four values to paste
# into your Vercel project env.
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
# Long random string used to sign the Keystatic session cookie.
KEYSTATIC_SECRET=
# The GitHub App's slug (PUBLIC_ so the dashboard SPA can build the install URL).
PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=

# Per-post view counter, backed by a self-hosted Umami instance.
# Absent => the Umami script isn't loaded and the counter hides (no-op).
#
# PUBLIC_* ship in the client tracking <script> tag, so they are not secret:
#   PUBLIC_UMAMI_HOST       — base URL of your Umami deploy (no trailing slash)
#   PUBLIC_UMAMI_WEBSITE_ID — the website's UUID from Umami → Settings → Websites
PUBLIC_UMAMI_HOST=https://analytics.carnav.in
PUBLIC_UMAMI_WEBSITE_ID=
#
# Server-only: a read-only Umami login used to mint an API token for the
# inline "👁 N views" count. Create a dedicated user in Umami for this.
UMAMI_API_USER=
UMAMI_API_PASSWORD=
