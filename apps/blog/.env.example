# Keystatic GitHub mode (production /keystatic dashboard).
# In dev the dashboard uses local filesystem storage, so these are only needed
# for the deployed site. Generate them by deploying, opening
# https://blog.carnav.in/keystatic, and clicking "Connect to GitHub" — Keystatic
# walks you through creating the GitHub App and prints these four values to paste
# into your Vercel project env.
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
# Long random string used to sign the Keystatic session cookie.
KEYSTATIC_SECRET=
# The GitHub App's slug (PUBLIC_ so the dashboard SPA can build the install URL).
PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=

# Per-post view counter (Upstash Redis). Absent => counter no-ops.
# Auto-added on Vercel when you attach Upstash. The code reads either the
# native Upstash names (below) or the Marketplace/KV-style names
# (KV_REST_API_URL / KV_REST_API_TOKEN), so no rename is needed — just
# `vercel env pull` and whichever pair Vercel injected will work.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
