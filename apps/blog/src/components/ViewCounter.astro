---
// Read-only server island. Renders the pageview count for `slug`, read from
// the self-hosted Umami instance (see lib/views.ts). Recording + visitor
// dedupe happen in Umami's own tracking script, so this fragment carries no
// per-visitor data and is safe to cache at the edge.
import { getViews } from '../lib/views';

interface Props {
	slug: string;
}
const { slug } = Astro.props;

const views = await getViews(slug);

// Shared edge cache: Umami's count isn't real-time, so a slightly longer TTL
// avoids hammering its API on every render.
Astro.response.headers.set(
	'Cache-Control',
	'public, s-maxage=60, stale-while-revalidate=300',
);
---

{
	views !== null && (
		<span class="inline-flex items-center gap-2">
			<span aria-hidden="true">·</span>
			<span class="inline-flex items-center gap-1">
				<span aria-hidden="true">👁</span>
				<span class="tabular-nums">{views.toLocaleString()}</span>
				<span>views</span>
			</span>
		</span>
	)
}
