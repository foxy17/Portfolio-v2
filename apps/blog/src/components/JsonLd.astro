---
import { SITE_TITLE, SITE_AUTHOR, SITE_URL } from '../consts';

interface Props {
	type: 'website' | 'article';
	title: string;
	description: string;
	image: string;
	canonicalURL: URL;
	pubDate?: Date;
	updatedDate?: Date;
	author?: string;
	tags?: string[];
	wordCount?: number;
	category?: string;
}

const {
	type,
	title,
	description,
	image,
	canonicalURL,
	pubDate,
	updatedDate,
	author = SITE_AUTHOR,
	tags = [],
	wordCount,
	category,
} = Astro.props;

const personId = 'https://carnav.in/#person';
const websiteId = `${SITE_URL}/#website`;

const person = {
	'@type': 'Person',
	'@id': personId,
	name: SITE_AUTHOR,
	url: 'https://carnav.in/',
	image: 'https://www.carnav.in/static/arnav.png',
	jobTitle: 'Software Engineer',
	description:
		'Software engineer focused on web platforms, frontend performance, and developer tooling.',
	knowsAbout: [
		'Web Performance',
		'Frontend Engineering',
		'JavaScript',
		'TypeScript',
		'React',
		'Astro',
		'Node.js',
		'GraphQL',
		'Developer Tooling',
	],
	sameAs: [
		'https://github.com/foxy17',
		'https://twitter.com/arnav_sde',
		'https://www.linkedin.com/in/arnavschauhan/',
	],
};

const website = {
	'@type': 'WebSite',
	'@id': websiteId,
	url: SITE_URL,
	name: SITE_TITLE,
	description:
		'Notes on web engineering, frontend performance, and developer tooling.',
	publisher: { '@id': personId },
	inLanguage: 'en',
	potentialAction: {
		'@type': 'SearchAction',
		target: `${SITE_URL}/?q={search_term_string}`,
		'query-input': 'required name=search_term_string',
	},
};

const graph: Record<string, unknown>[] = [person, website];

if (type === 'article' && pubDate) {
	const article: Record<string, unknown> = {
		'@type': 'BlogPosting',
		'@id': `${canonicalURL.href}#article`,
		headline: title,
		description,
		image: [image],
		datePublished: pubDate.toISOString(),
		dateModified: (updatedDate ?? pubDate).toISOString(),
		author: { '@id': personId, name: author },
		publisher: { '@id': personId },
		mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalURL.href },
		isPartOf: { '@id': websiteId },
		keywords: tags.join(', '),
		inLanguage: 'en',
		url: canonicalURL.href,
	};

	if (wordCount && wordCount > 0) {
		article.wordCount = wordCount;
		article.timeRequired = `PT${Math.max(1, Math.round(wordCount / 200))}M`;
	}
	if (category) article.articleSection = category;

	graph.push(article);

	// Breadcrumb trail helps search/AI engines understand site hierarchy.
	graph.push({
		'@type': 'BreadcrumbList',
		'@id': `${canonicalURL.href}#breadcrumb`,
		itemListElement: [
			{
				'@type': 'ListItem',
				position: 1,
				name: 'Home',
				item: `${SITE_URL}/`,
			},
			{
				'@type': 'ListItem',
				position: 2,
				name: title,
				item: canonicalURL.href,
			},
		],
	});
}

const jsonLd = { '@context': 'https://schema.org', '@graph': graph };

// Escape characters that could break out of a <script> element or trip up
// parsers if the data ever contains `</script>` or U+2028 / U+2029.
const safeJson = JSON.stringify(jsonLd).replace(
	/[<\u2028\u2029]/g,
	(c) => `\\u${c.charCodeAt(0).toString(16).padStart(4, '0')}`,
);
---

<script
	type="application/ld+json"
	is:inline
	set:html={safeJson}
/>
