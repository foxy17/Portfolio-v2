---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (
	await getCollection('blog', ({ data }) =>
		import.meta.env.PROD ? !data.draft : true,
	)
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
                <main id="skip" class="w-[960px]">
			<section>
				<ul class="flex flex-wrap gap-8 list-none m-0 p-0">
					{
						posts.map((post, index) => (
							<li class={`${index === 0 ? 'w-full mb-4 text-center' : 'w-[calc(50%-1rem)]'}`}>
								<a href={`/${post.id}/`} class="block">
									{post.data.heroImage && (
										<Image
											src={post.data.heroImage}
											alt={`Cover image for ${post.data.title}`}
											widths={
												index === 0
													? [480, 720, 960, 1280]
													: [240, 360, 480, 720]
											}
											sizes={
												index === 0
													? '(max-width: 720px) 100vw, 960px'
													: '(max-width: 720px) 100vw, 460px'
											}
											formats={['avif', 'webp']}
											loading={index === 0 ? 'eager' : 'lazy'}
											fetchpriority={index === 0 ? 'high' : 'auto'}
											decoding="async"
											class={`${index === 0 ? 'w-full' : ''} mb-2 rounded-xl bg-blog-surface dark:bg-blog-dark-surface transition-all duration-200 ease-in-out hover:shadow-card dark:hover:shadow-card-dark`}
										/>
									)}
									<h4 class="title m-0 text-gray-900 dark:text-beige leading-none transition-colors duration-200 ease-in-out hover:text-flat-blue dark:hover:text-flat-blue text-[${index === 0 ? '2.369rem' : 'inherit'}]">
										{post.data.title}
									</h4>
									<p class="date m-0 text-gray-500 dark:text-beige transition-colors duration-200 ease-in-out hover:text-flat-blue dark:hover:text-flat-blue">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	@reference "../styles/global.css";
	@media (max-width: 720px) {
		main {
			width: 100% !important;
		}
		
		ul {
			@apply gap-2;
		}
		
		ul li {
			@apply w-full text-center;
		}
		
		ul li:first-child {
			@apply mb-0;
		}
		
		ul li:first-child .title {
			@apply text-[1.563em];
		}
	}
</style>
