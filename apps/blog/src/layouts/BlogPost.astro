---
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	headings?: MarkdownHeading[];
	minutesRead?: string;
	prev?: CollectionEntry<'blog'> | null;
	next?: CollectionEntry<'blog'> | null;
	related?: CollectionEntry<'blog'>[];
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	tags = [],
	author,
	ogImage,
	headings = [],
	minutesRead,
	prev = null,
	next = null,
	related = [],
} = Astro.props;
const socialImage =
	ogImage ?? (heroImage ? heroImage.src : undefined);
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
const tocTree = tocHeadings.reduce<
	(MarkdownHeading & { children: MarkdownHeading[] })[]
>((items, heading) => {
	if (heading.depth === 2 || items.length === 0) {
		items.push({ ...heading, children: [] });
		return items;
	}

	items[items.length - 1].children.push(heading);
	return items;
}, []);
---

<html lang="en">
	<head>
		<BaseHead
			title={title}
			description={description}
			type="article"
			image={socialImage}
			pubDate={pubDate}
			updatedDate={updatedDate}
			author={author}
			tags={tags}
		/>
	</head>

	<body>
		<Header />
		<main id="skip" class="w-full max-w-full m-0 p-0">
			<article>
				<div class="w-full max-w-[720px] mx-auto px-3 sm:px-4">
					{
						heroImage && (
							<Image
								src={heroImage}
								alt={`Cover image for ${title}`}
								widths={[480, 720, 1080]}
								sizes="(max-width: 720px) 100vw, 720px"
								formats={['avif', 'webp']}
								loading="eager"
								fetchpriority="high"
								decoding="async"
								class="block w-full h-auto rounded-xl shadow-card dark:shadow-card-dark bg-blog-surface dark:bg-blog-dark-surface"
							/>
						)
					}
				</div>
				<div class="prose dark:prose-invert w-full max-w-[720px] mx-auto px-3 py-4 sm:px-4 text-gray-700 dark:text-beige">
					<div class="mb-4 py-4 text-center">
						<div class="mb-2 text-gray-500 dark:text-beige flex items-center justify-center gap-2 flex-wrap">
							<FormattedDate date={pubDate} />
							{minutesRead && (
								<>
									<span aria-hidden="true">·</span>
									<span>{minutesRead}</span>
								</>
							)}
						</div>
						{
							updatedDate && (
								<div class="italic text-gray-500 dark:text-beige text-sm mb-2">
									Last updated on <FormattedDate date={updatedDate} />
								</div>
							)
						}
						<h1 class="m-0 mb-2">{title}</h1>
						<hr class="border-t border-blog-border dark:border-blog-dark-border" />
					</div>

					{tocHeadings.length >= 2 && (
						<div class="not-prose mb-8" data-toc-wrapper>
							<details
								class="toc-card rounded-lg border border-blog-border bg-blog-surface p-4 dark:border-blog-dark-border dark:bg-blog-dark-surface"
								open
								data-toc
							>
								<summary class="cursor-pointer text-sm font-bold uppercase tracking-[0.14em] text-gray-600 transition-colors hover:text-flat-blue dark:text-gray-400 dark:hover:text-flat-blue">
									Table of contents
								</summary>
								<ul class="m-0 mt-3 flex list-none flex-col gap-2 p-0 text-sm leading-6">
									{tocTree.map((h) => (
										<li>
											<a
												href={`#${h.slug}`}
												class="text-gray-700 no-underline transition-colors hover:text-flat-blue dark:text-beige dark:hover:text-flat-blue"
											>
												{h.text}
											</a>
											{h.children.length > 0 && (
												<ul class="mt-1 flex list-none flex-col gap-1 border-l border-blog-border pl-3 dark:border-blog-dark-border">
													{h.children.map((child) => (
														<li>
															<a
																href={`#${child.slug}`}
																class="text-gray-500 no-underline transition-colors hover:text-flat-blue dark:text-gray-400 dark:hover:text-flat-blue"
															>
																{child.text}
															</a>
														</li>
													))}
												</ul>
											)}
										</li>
									))}
								</ul>
							</details>
						</div>
					)}

					<slot />

					{tags.length > 0 && (
						<div class="not-prose mt-12 pt-6 border-t border-blog-border dark:border-blog-dark-border">
							<p class="text-sm text-gray-500 dark:text-beige mb-2">Tagged</p>
							<ul class="flex flex-wrap gap-2 list-none m-0 p-0">
								{tags.map((tag) => (
									<li>
										<a
											href={`/tags/${tag}/`}
											class="inline-block px-3 py-1 rounded-full border border-blog-border dark:border-blog-dark-border text-sm text-gray-700 dark:text-beige hover:text-flat-blue hover:border-flat-blue dark:hover:text-flat-blue dark:hover:border-flat-blue transition-colors no-underline"
										>
											#{tag}
										</a>
									</li>
								))}
							</ul>
						</div>
					)}

					{(prev || next) && (
						<nav
							class="not-prose mt-8 pt-6 border-t border-blog-border dark:border-blog-dark-border flex flex-col gap-4 sm:grid sm:grid-cols-2"
							aria-label="Post navigation"
						>
							{prev ? (
								<a
									href={`/${prev.id}/`}
									class="block text-left text-gray-700 dark:text-beige no-underline hover:text-flat-blue dark:hover:text-flat-blue"
								>
									<span class="block text-xs text-gray-500 dark:text-gray-400">
										← Previous
									</span>
									<span class="block font-medium">{prev.data.title}</span>
								</a>
							) : (
								<span />
							)}
							{next ? (
								<a
									href={`/${next.id}/`}
									class="block text-left sm:text-right text-gray-700 dark:text-beige no-underline hover:text-flat-blue dark:hover:text-flat-blue"
								>
									<span class="block text-xs text-gray-500 dark:text-gray-400">
										Next →
									</span>
									<span class="block font-medium">{next.data.title}</span>
								</a>
							) : (
								<span />
							)}
						</nav>
					)}

					{related.length > 0 && (
						<aside class="not-prose mt-12 pt-6 border-t border-blog-border dark:border-blog-dark-border">
							<h2 class="text-lg font-semibold text-gray-900 dark:text-beige mb-4">
								Related posts
							</h2>
							<ul class="list-none m-0 p-0 flex flex-col gap-3">
								{related.map((r) => (
									<li>
										<a
											href={`/${r.id}/`}
											class="block text-gray-700 dark:text-beige no-underline hover:text-flat-blue dark:hover:text-flat-blue"
										>
											<span class="font-medium">{r.data.title}</span>
											<span class="block text-sm text-gray-500 dark:text-gray-400">
												<FormattedDate date={r.data.pubDate} />
											</span>
										</a>
									</li>
								))}
							</ul>
						</aside>
					)}
				</div>
			</article>
		</main>
		<Footer />
		<script>
			function initFloatingToc() {
				if (typeof window.__blogTocCleanup === 'function') {
					window.__blogTocCleanup();
				}

				const wrapper = document.querySelector('[data-toc-wrapper]');
				const toc = document.querySelector('[data-toc]');

				if (!wrapper || !toc) {
					window.__blogTocCleanup = null;
					return;
				}

				let docked = toc.dataset.docked === 'true';
				let ticking = false;

				function hasRightGutter() {
					const contentWidth = 720;
					const tocWidth = 256;
					const gap = 32;
					return (window.innerWidth - contentWidth) / 2 >= tocWidth + gap;
				}

				function animateToState(nextDocked) {
					if (nextDocked === docked) return;

					const first = toc.getBoundingClientRect();
					wrapper.style.minHeight = `${wrapper.offsetHeight}px`;
					toc.dataset.docked = nextDocked ? 'true' : 'false';
					docked = nextDocked;
					const last = toc.getBoundingClientRect();
					const deltaX = first.left - last.left;
					const deltaY = first.top - last.top;

					toc.style.transition = 'none';
					toc.style.transform = `translate(${deltaX}px, ${deltaY}px)`;

					requestAnimationFrame(() => {
						toc.style.transition = '';
						toc.style.transform = '';
					});
				}

				function updateToc() {
					ticking = false;
					const shouldDock =
						hasRightGutter() && wrapper.getBoundingClientRect().bottom <= 96;

					if (!shouldDock && !docked) {
						wrapper.style.minHeight = '';
					}

					animateToState(shouldDock);
				}

				function requestUpdate() {
					if (ticking) return;
					ticking = true;
					requestAnimationFrame(updateToc);
				}

				window.addEventListener('scroll', requestUpdate, { passive: true });
				window.addEventListener('resize', requestUpdate);
				updateToc();

				window.__blogTocCleanup = () => {
					window.removeEventListener('scroll', requestUpdate);
					window.removeEventListener('resize', requestUpdate);
				};
			}

			window.__blogInitFloatingToc = initFloatingToc;

			if (!window.__blogTocPageLoadBound) {
				window.__blogTocPageLoadBound = true;
				document.addEventListener('astro:page-load', () => {
					window.__blogInitFloatingToc?.();
				});
			}

			initFloatingToc();
		</script>
	</body>
</html>

<style>
	.toc-card {
		transition:
			transform 280ms ease,
			box-shadow 200ms ease,
			opacity 200ms ease;
	}

	.toc-card[data-docked='true'] {
		position: fixed;
		top: 6rem;
		right: calc((100vw - 720px) / 2 - 18rem);
		z-index: 30;
		width: 16rem;
		max-height: calc(100vh - 8rem);
		overflow: auto;
		box-shadow: 0 18px 45px rgba(15, 13, 14, 0.16);
	}

	:global(.dark) .toc-card[data-docked='true'] {
		box-shadow: 0 18px 45px rgba(0, 0, 0, 0.36);
	}

	@media (max-width: 1279px) {
		.toc-card[data-docked='true'] {
			position: static;
			width: auto;
			max-height: none;
			overflow: visible;
			box-shadow: none;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.toc-card {
			transition: none;
		}
	}
</style>
