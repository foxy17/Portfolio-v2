---
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	headings?: MarkdownHeading[];
	minutesRead?: string;
	prev?: CollectionEntry<'blog'> | null;
	next?: CollectionEntry<'blog'> | null;
	related?: CollectionEntry<'blog'>[];
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	tags = [],
	author,
	ogImage,
	headings = [],
	minutesRead,
	prev = null,
	next = null,
	related = [],
} = Astro.props;
const socialImage =
	ogImage ?? (heroImage ? heroImage.src : undefined);
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<html lang="en">
	<head>
		<BaseHead
			title={title}
			description={description}
			type="article"
			image={socialImage}
			pubDate={pubDate}
			updatedDate={updatedDate}
			author={author}
			tags={tags}
		/>
	</head>

	<body>
		<Header />
		<main id="skip" class="w-full max-w-full m-0 p-0">
			<article>
				<div class="w-full max-w-[720px] mx-auto px-3 sm:px-4">
					{
						heroImage && (
							<Image
								src={heroImage}
								alt={`Cover image for ${title}`}
								widths={[480, 720, 1080]}
								sizes="(max-width: 720px) 100vw, 720px"
								formats={['avif', 'webp']}
								loading="eager"
								fetchpriority="high"
								decoding="async"
								class="block w-full h-auto rounded-xl shadow-card dark:shadow-card-dark bg-blog-surface dark:bg-blog-dark-surface"
							/>
						)
					}
				</div>
				<div class="prose dark:prose-invert w-full max-w-[720px] mx-auto px-3 py-4 sm:px-4 text-gray-700 dark:text-beige">
					<div class="mb-4 py-4 text-center">
						<div class="mb-2 text-gray-500 dark:text-beige flex items-center justify-center gap-2 flex-wrap">
							<FormattedDate date={pubDate} />
							{minutesRead && (
								<>
									<span aria-hidden="true">·</span>
									<span>{minutesRead}</span>
								</>
							)}
						</div>
						{
							updatedDate && (
								<div class="italic text-gray-500 dark:text-beige text-sm mb-2">
									Last updated on <FormattedDate date={updatedDate} />
								</div>
							)
						}
						<h1 class="m-0 mb-2">{title}</h1>
						<hr class="border-t border-blog-border dark:border-blog-dark-border" />
					</div>

					{tocHeadings.length >= 3 && (
						<details class="not-prose mb-6 rounded-lg border border-blog-border bg-blog-surface dark:border-blog-dark-border dark:bg-blog-dark-surface p-4">
							<summary class="cursor-pointer font-semibold text-gray-800 dark:text-beige">
								Table of contents
							</summary>
							<ul class="mt-3 list-none pl-0 m-0 flex flex-col gap-1.5">
								{tocHeadings.map((h) => (
									<li class={h.depth === 3 ? 'pl-4' : ''}>
										<a
											href={`#${h.slug}`}
											class="text-gray-700 dark:text-beige hover:text-flat-blue dark:hover:text-flat-blue no-underline"
										>
											{h.text}
										</a>
									</li>
								))}
							</ul>
						</details>
					)}

					<slot />

					{tags.length > 0 && (
						<div class="not-prose mt-12 pt-6 border-t border-blog-border dark:border-blog-dark-border">
							<p class="text-sm text-gray-500 dark:text-beige mb-2">Tagged</p>
							<ul class="flex flex-wrap gap-2 list-none m-0 p-0">
								{tags.map((tag) => (
									<li>
										<a
											href={`/tags/${tag}/`}
											class="inline-block px-3 py-1 rounded-full border border-blog-border dark:border-blog-dark-border text-sm text-gray-700 dark:text-beige hover:text-flat-blue hover:border-flat-blue dark:hover:text-flat-blue dark:hover:border-flat-blue transition-colors no-underline"
										>
											#{tag}
										</a>
									</li>
								))}
							</ul>
						</div>
					)}

					{(prev || next) && (
						<nav
							class="not-prose mt-8 pt-6 border-t border-blog-border dark:border-blog-dark-border flex flex-col gap-4 sm:grid sm:grid-cols-2"
							aria-label="Post navigation"
						>
							{prev ? (
								<a
									href={`/${prev.id}/`}
									class="block text-left text-gray-700 dark:text-beige no-underline hover:text-flat-blue dark:hover:text-flat-blue"
								>
									<span class="block text-xs text-gray-500 dark:text-gray-400">
										← Previous
									</span>
									<span class="block font-medium">{prev.data.title}</span>
								</a>
							) : (
								<span />
							)}
							{next ? (
								<a
									href={`/${next.id}/`}
									class="block text-left sm:text-right text-gray-700 dark:text-beige no-underline hover:text-flat-blue dark:hover:text-flat-blue"
								>
									<span class="block text-xs text-gray-500 dark:text-gray-400">
										Next →
									</span>
									<span class="block font-medium">{next.data.title}</span>
								</a>
							) : (
								<span />
							)}
						</nav>
					)}

					{related.length > 0 && (
						<aside class="not-prose mt-12 pt-6 border-t border-blog-border dark:border-blog-dark-border">
							<h2 class="text-lg font-semibold text-gray-900 dark:text-beige mb-4">
								Related posts
							</h2>
							<ul class="list-none m-0 p-0 flex flex-col gap-3">
								{related.map((r) => (
									<li>
										<a
											href={`/${r.id}/`}
											class="block text-gray-700 dark:text-beige no-underline hover:text-flat-blue dark:hover:text-flat-blue"
										>
											<span class="font-medium">{r.data.title}</span>
											<span class="block text-sm text-gray-500 dark:text-gray-400">
												<FormattedDate date={r.data.pubDate} />
											</span>
										</a>
									</li>
								))}
							</ul>
						</aside>
					)}
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
