---
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import TableOfContents from '../components/TableOfContents.astro';
import ViewCounter from '../components/ViewCounter.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	slug?: string;
	headings?: MarkdownHeading[];
	minutesRead?: string;
	wordCount?: number;
	prev?: CollectionEntry<'blog'> | null;
	next?: CollectionEntry<'blog'> | null;
	related?: CollectionEntry<'blog'>[];
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	tags = [],
	author,
	category,
	ogImage,
	slug,
	headings = [],
	minutesRead,
	wordCount,
	prev = null,
	next = null,
	related = [],
} = Astro.props;
const socialImage =
	ogImage ?? (heroImage ? heroImage.src : undefined);
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
const tocTree = tocHeadings.reduce<
	(MarkdownHeading & { children: MarkdownHeading[] })[]
>((items, heading) => {
	if (heading.depth === 2 || items.length === 0) {
		items.push({ ...heading, children: [] });
		return items;
	}

	items[items.length - 1].children.push(heading);
	return items;
}, []);
---

<html lang="en">
	<head>
		<BaseHead
			title={title}
			description={description}
			type="article"
			image={socialImage}
			pubDate={pubDate}
			updatedDate={updatedDate}
			author={author}
			tags={tags}
			wordCount={wordCount}
			category={category}
		/>
	</head>

	<body>
		<Header />
		<main id="skip" class="w-full max-w-full m-0 p-0">
			<article>
				<div class="w-full max-w-[720px] mx-auto px-3 sm:px-4">
					{
						heroImage && (
							<Image
								src={heroImage}
								alt={`Cover image for ${title}`}
								widths={[480, 720, 1080]}
								sizes="(max-width: 720px) 100vw, 720px"
								formats={['avif', 'webp']}
								loading="eager"
								fetchpriority="high"
								decoding="async"
								class="block w-full h-auto rounded-xl shadow-card dark:shadow-card-dark bg-blog-surface dark:bg-blog-dark-surface"
							/>
						)
					}
				</div>
				<div class="prose dark:prose-invert w-full max-w-[720px] mx-auto px-3 py-4 sm:px-4 text-gray-700 dark:text-beige">
					<div class="mb-4 py-4 text-center">
						<div class="mb-2 text-gray-500 dark:text-beige flex items-center justify-center gap-2 flex-wrap">
							<FormattedDate date={pubDate} />
							{minutesRead && (
								<>
									<span aria-hidden="true">·</span>
									<span>{minutesRead}</span>
								</>
							)}
							{slug && (
								<>
									<span aria-hidden="true">·</span>
									<span data-view-counter data-slug={slug}>
										<ViewCounter slug={slug} server:defer>
											<span slot="fallback" class="opacity-50">
												👁 —
											</span>
										</ViewCounter>
									</span>
								</>
							)}
						</div>
						{
							updatedDate && (
								<div class="italic text-gray-500 dark:text-beige text-sm mb-2">
									Last updated on <FormattedDate date={updatedDate} />
								</div>
							)
						}
						<h1 class="m-0 mb-2">{title}</h1>
						<hr class="border-t border-blog-border dark:border-blog-dark-border" />
					</div>

					{tocHeadings.length >= 2 && (
						<div class="not-prose mb-8">
							<details
								class="rounded-lg border border-blog-border bg-blog-surface px-3 py-1.5 dark:border-blog-dark-border dark:bg-blog-dark-surface"
								open
								data-toc-inline
							>
								<summary class="cursor-pointer select-none text-[11px] font-bold uppercase tracking-[0.14em] text-gray-500 transition-colors hover:text-flat-blue dark:text-gray-400 dark:hover:text-flat-blue">
									Contents
								</summary>
								<div class="mt-1.5">
									<TableOfContents items={tocTree} />
								</div>
							</details>
						</div>
					)}

					{tocHeadings.length >= 2 && (
						<nav
							class="toc-fixed not-prose"
							aria-label="Table of contents"
							data-toc-fixed
						>
							<p class="mb-1.5 px-2 text-[11px] font-bold uppercase tracking-[0.14em] text-gray-400 dark:text-gray-500">
								On this page
							</p>
							<TableOfContents items={tocTree} />
						</nav>
					)}

					<slot />

					{tags.length > 0 && (
						<div class="not-prose mt-12 pt-6 border-t border-blog-border dark:border-blog-dark-border">
							<p class="text-sm text-gray-500 dark:text-beige mb-2">Tagged</p>
							<ul class="flex flex-wrap gap-2 list-none m-0 p-0">
								{tags.map((tag) => (
									<li>
										<a
											href={`/tags/${tag}/`}
											class="inline-block px-3 py-1 rounded-full border border-blog-border dark:border-blog-dark-border text-sm text-gray-700 dark:text-beige hover:text-flat-blue hover:border-flat-blue dark:hover:text-flat-blue dark:hover:border-flat-blue transition-colors no-underline"
										>
											#{tag}
										</a>
									</li>
								))}
							</ul>
						</div>
					)}

					{(prev || next) && (
						<nav
							class="not-prose mt-8 pt-6 border-t border-blog-border dark:border-blog-dark-border flex flex-col gap-4 sm:grid sm:grid-cols-2"
							aria-label="Post navigation"
						>
							{prev ? (
								<a
									href={`/${prev.id}/`}
									class="block text-left text-gray-700 dark:text-beige no-underline hover:text-flat-blue dark:hover:text-flat-blue"
								>
									<span class="block text-xs text-gray-500 dark:text-gray-400">
										← Previous
									</span>
									<span class="block font-medium">{prev.data.title}</span>
								</a>
							) : (
								<span />
							)}
							{next ? (
								<a
									href={`/${next.id}/`}
									class="block text-left sm:text-right text-gray-700 dark:text-beige no-underline hover:text-flat-blue dark:hover:text-flat-blue"
								>
									<span class="block text-xs text-gray-500 dark:text-gray-400">
										Next →
									</span>
									<span class="block font-medium">{next.data.title}</span>
								</a>
							) : (
								<span />
							)}
						</nav>
					)}

					{related.length > 0 && (
						<aside class="not-prose mt-12 pt-6 border-t border-blog-border dark:border-blog-dark-border">
							<h2 class="text-lg font-semibold text-gray-900 dark:text-beige mb-4">
								Related posts
							</h2>
							<ul class="list-none m-0 p-0 flex flex-col gap-3">
								{related.map((r) => (
									<li>
										<a
											href={`/${r.id}/`}
											class="block text-gray-700 dark:text-beige no-underline hover:text-flat-blue dark:hover:text-flat-blue"
										>
											<span class="font-medium">{r.data.title}</span>
											<span class="block text-sm text-gray-500 dark:text-gray-400">
												<FormattedDate date={r.data.pubDate} />
											</span>
										</a>
									</li>
								))}
							</ul>
						</aside>
					)}
				</div>
			</article>
		</main>
		<Footer />
		<script>
			function initBlogToc() {
				const inline = document.querySelector('[data-toc-inline]');
				const fixed = document.querySelector('[data-toc-fixed]');
				if (!fixed || !inline) return;

				if (window.__blogTocObserver) {
					window.__blogTocObserver.disconnect();
				}

				// Fade the fixed sidebar in only once the inline TOC has scrolled
				// completely out of view above the viewport.
				const observer = new IntersectionObserver(
					(entries) => {
						const entry = entries[0];
						if (!entry) return;
						const goneAbove =
							!entry.isIntersecting && entry.boundingClientRect.top < 0;
						fixed.classList.toggle('is-visible', goneAbove);
					},
					{ threshold: 0 },
				);

				observer.observe(inline);
				window.__blogTocObserver = observer;
			}

			if (!window.__blogTocBound) {
				window.__blogTocBound = true;
				document.addEventListener('astro:page-load', initBlogToc);
			}

			initBlogToc();
		</script>
		<script>
			// Record one view per visitor per day. The localStorage flag skips the
			// POST entirely on repeat same-day loads (0 Redis calls); the server
			// still dedupes via the seen: gate as a cross-device backstop.
			function recordBlogView() {
				const host = document.querySelector('[data-view-counter]');
				const slug = host?.getAttribute('data-slug');
				if (!host || !slug) return;

				const day = new Date().toISOString().slice(0, 10).replace(/-/g, '');
				const key = `viewed:${slug}:${day}`;
				try {
					if (localStorage.getItem(key)) return;
				} catch {
					// localStorage blocked (private mode) — fall through and let the
					// server-side gate handle dedupe.
				}

				fetch(`/api/view?slug=${encodeURIComponent(slug)}`, {
					method: 'POST',
					keepalive: true,
				})
					.then((r) => (r.ok ? r.json() : null))
					.then((data) => {
						try {
							localStorage.setItem(key, '1');
						} catch {
							/* ignore */
						}
						if (data && typeof data.views === 'number') {
							const num = host.querySelector('[data-view-count]');
							if (num) num.textContent = data.views.toLocaleString();
						}
					})
					.catch(() => {});
			}

			if (!window.__blogViewBound) {
				window.__blogViewBound = true;
				document.addEventListener('astro:page-load', recordBlogView);
			}

			recordBlogView();
		</script>
	</body>
</html>

<style>
	.toc-fixed {
		display: none;
		position: fixed;
		top: 6rem;
		right: calc((100vw - 720px) / 2 - 18rem);
		width: 16rem;
		max-height: calc(100vh - 9rem);
		overflow-y: auto;
		opacity: 0;
		transform: translateY(6px);
		pointer-events: none;
		transition:
			opacity 240ms ease,
			transform 240ms ease;
		z-index: 30;
	}

	.toc-fixed.is-visible {
		opacity: 1;
		transform: none;
		pointer-events: auto;
	}

	/* Only dock into the gutter when there is real room beside the 720px column. */
	@media (min-width: 1296px) {
		.toc-fixed {
			display: block;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.toc-fixed {
			transition: opacity 240ms ease;
			transform: none;
		}
	}
</style>
